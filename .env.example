# Variáveis de ambiente para price_monitoring
# Copie este arquivo como .env e preencha com seus valores

# Caminho para o Python (opcional - se não definido, usa o do PATH)
# Exemplo Windows: C:\Users\SeuNome\AppData\Local\Programs\Python\Python313\python.exe
# Exemplo WSL/Linux: /usr/bin/python3
PYTHON_PATH=

# Caminho para o diretório do projeto (opcional - se não definido, usa o diretório atual)
# Deixe vazio para usar automaticamente a pasta do projeto
PROJETO_PATH=

# Token GitHub pessoal (opcional - para push sem autenticação)
GITHUB_TOKEN=
